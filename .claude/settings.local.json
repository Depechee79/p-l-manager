{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(firebase:*)",
      "Bash(git:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(cd:*)",
      "Bash(curl:*)",
      "Bash(ping:*)",
      "Bash(netstat:*)",
      "Bash(findstr:*)",
      "Bash(tasklist:*)",
      "Bash(taskkill:*)",
      "Bash(timeout:*)",
      "Bash(playwright:*)",
      "mcp__Claude_in_Chrome__navigate"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit --pretty 2>&1 | head -20",
            "timeout": 30000,
            "fileMatcher": "\\.(ts|tsx)$"
          }
        ]
      }
    ]
  }
}
