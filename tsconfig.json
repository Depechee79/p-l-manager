{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@services": [
        "./src/services"
      ],
      "@services/*": [
        "./src/core/services/*",
        "./src/services/*"
      ],
      "@context": [
        "./src/context"
      ],
      "@context/*": [
        "./src/core/context/*"
      ],
      "@types": [
        "./src/types"
      ],
      "@types/*": [
        "./src/types/*"
      ],
      "@utils": [
        "./src/utils"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@hooks": [
        "./src/hooks"
      ],
      "@hooks/*": [
        "./src/core/hooks/*",
        "./src/hooks/*"
      ],
      "@pages": [
        "./src/pages"
      ],
      "@pages/*": [
        "./src/pages/*"
      ],
      "@components": [
        "./src/shared/components"
      ],
      "@components/*": [
        "./src/shared/components/*"
      ],
      "@features/*": [
        "./src/features/*"
      ],
      "@core": [
        "./src/core"
      ],
      "@core/*": [
        "./src/core/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/test",
    "**/*.test.tsx",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.spec.ts",
    "src/core/utils/migration.ts"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}